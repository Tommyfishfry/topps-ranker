,"potentialAction":[{"@type":"ReadAction","target":["https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/"]}]},{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#primaryimage","url":"https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi_dried_tomatoes_4.jpg","contentUrl":"https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi_dried_tomatoes_4.jpg","width":1067,"height":1600,"caption":"A piece of toast on a blue plate topped with ricotta and semi dried tomatoes"},{"@type":"BreadcrumbList","@id":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#breadcrumb","itemListElement":[{"@type":"ListItem","position":1,"name":"Home","item":"https:\/\/www.heynutritionlady.com\/"},{"@type":"ListItem","position":2,"name":"Recipes","item":"https:\/\/www.heynutritionlady.com\/recipes\/"},{"@type":"ListItem","position":3,"name":"Side Dishes","item":"https:\/\/www.heynutritionlady.com\/category\/side-dishes\/"},{"@type":"ListItem","position":4,"name":"Semi-Dried Tomatoes (Easy Oven-Roasted Method)"}]},{"@type":"WebSite","@id":"https:\/\/www.heynutritionlady.com\/#website","url":"https:\/\/www.heynutritionlady.com\/","name":"Hey Nutrition Lady","description":"","publisher":{"@id":"https:\/\/www.heynutritionlady.com\/#organization"},"potentialAction":[{"@type":"SearchAction","target":{"@type":"EntryPoint","urlTemplate":"https:\/\/www.heynutritionlady.com\/?s={search_term_string}"},"query-input":{"@type":"PropertyValueSpecification","valueRequired":true,"valueName":"search_term_string"}}],"inLanguage":"en-US"},{"@type":"Organization","@id":"https:\/\/www.heynutritionlady.com\/#organization","name":"Hey Nutrition Lady","url":"https:\/\/www.heynutritionlady.com\/","logo":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/www.heynutritionlady.com\/#\/schema\/logo\/image\/","url":"https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2018\/05\/hnl_logo_small.jpg","contentUrl":"https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2018\/05\/hnl_logo_small.jpg","width":400,"height":267,"caption":"Hey Nutrition Lady"},"image":{"@id":"https:\/\/www.heynutritionlady.com\/#\/schema\/logo\/image\/"},"sameAs":["https:\/\/www.facebook.com\/heynutritionlady\/"]},{"@type":"Person","@id":"https:\/\/www.heynutritionlady.com\/#\/schema\/person\/8634ce8fef91abb2d8ba34acafcbcc4d","name":"Katie Trant","image":{"@type":"ImageObject","inLanguage":"en-US","@id":"https:\/\/secure.gravatar.com\/avatar\/46718f5300dc07b29fd21f556e3add35cb4bcc3f56259cf8cc2ff55003cd8042?s=96&r=g","url":"https:\/\/secure.gravatar.com\/avatar\/46718f5300dc07b29fd21f556e3add35cb4bcc3f56259cf8cc2ff55003cd8042?s=96&r=g","contentUrl":"https:\/\/secure.gravatar.com\/avatar\/46718f5300dc07b29fd21f556e3add35cb4bcc3f56259cf8cc2ff55003cd8042?s=96&r=g","caption":"Katie Trant"},"sameAs":["https:\/\/www.heynutritionlady.com\/about-katie-2\/"],"honorificPrefix":"Ms","honorificSuffix":"MSc","gender":"female","knowsAbout":["nutrition","food","health","vegetarian recipes"],"knowsLanguage":["English","Swedish"],"url":"https:\/\/www.heynutritionlady.com\/about-katie-2"},{"@type":"Recipe","name":"Semi-Dried Tomatoes (Easy Oven-Roasted Method)","author":{"@id":"https:\/\/www.heynutritionlady.com\/#\/schema\/person\/8634ce8fef91abb2d8ba34acafcbcc4d"},"description":"These semi-dried tomatoes are rich, concentrated, and bursting with sweet tomato flavor. Slowly roasted in the oven, they’re easy to make at home and perfect for adding to salads, sandwiches, pizzas, or grain bowls. Make a double batch and freeze them for later — a simple way to enjoy peak tomato flavor all year long.","datePublished":"2019-09-17T23:58:11+00:00","image":["https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi-dried-tomatoes-SQ.jpg","https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi-dried-tomatoes-SQ-500x500.jpg","https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi-dried-tomatoes-SQ-500x375.jpg","https:\/\/www.heynutritionlady.com\/wp-content\/uploads\/2019\/09\/semi-dried-tomatoes-SQ-480x270.jpg"],"recipeYield":["10"],"prepTime":"PT10M","cookTime":"PT60M","totalTime":"PT70M","recipeIngredient":["1 lb cherry tomatoes","1 Tbsp extra virgin olive oil","1 tsp dried herbs (I used basil and oregano)","1\/4 tsp sea salt"],"recipeInstructions":[{"@type":"HowToStep","text":"Preheat your oven to 300°F \/ 150°C. Line two large baking sheets with parchment paper.","name":"Heat","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-0"},{"@type":"HowToStep","text":"Slice the tomatoes in half.","name":"Slice","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-1"},{"@type":"HowToStep","text":"Place the tomatoes in a bowl with the olive oil, herbs, salt, and pepper. Toss to combine well.","name":"Toss","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-2"},{"@type":"HowToStep","text":"Arrange the tomatoes cut-side up on the prepared baking sheets.","name":"Arrange","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-3"},{"@type":"HowToStep","text":"Bake for one hour, or until tomatoes have shrivelled and are just the tiniest bit brown around the edges.","name":"Bake","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-4"},{"@type":"HowToStep","text":"Allow the semi-dried tomatoes to cool completely.","name":"Cool","url":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#wprm-recipe-14221-step-0-5"}],"aggregateRating":{"@type":"AggregateRating","ratingValue":"5","ratingCount":"6","reviewCount":"5"},"review":[{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I recently came across a recipe calling for semi dried tomatoes. Never heard of them, so I googled and came across this recipe (along with premade ones for sale for a lot more money than it costs to make them yourself). I don’t think I’ll ever use sun dried tomatoes again! I’ve made at least a half dozen batches of this so far. I’ve used them to make a vinaigrette, as a topping on white pizza, and my favorite - blasting with a stick blender and a little bit of cream and adding it to marinara. So, so good!! Thank you for sharing this simple but genius recipe!","author":{"@type":"Person","name":"Lauri"},"datePublished":"2024-06-13"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I commented before but tonight I roasted the cherry tomatoes exactly as you instructed- the full hour at 300. Even better, sweeter and drier than my in a hurry attempt in September. They are going to be delicious in frittata !","author":{"@type":"Person","name":"Heather"},"datePublished":"2019-10-03"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"Well, that was easy ... and fast!!   Mine are in the oven now, and once done and cooled will be popped in the freezer.  What a great way to save September's harvest for winter consumption.  Thank you, Katie.","author":{"@type":"Person","name":"alice k mynett"},"datePublished":"2019-09-26"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I have so many cherry tomatoes from the garden. Thanks for a great idea that I can try without having to buy anything. Pinned of course so I remember this next year.","author":{"@type":"Person","name":"Angela reyes"},"datePublished":"2019-09-22"},{"@type":"Review","reviewRating":{"@type":"Rating","ratingValue":"5"},"reviewBody":"I tried these on pizza. Definitely the way to go. So flavourful and not at all soggy!","author":{"@type":"Person","name":"Heather"},"datePublished":"2019-09-18"}],"recipeCategory":["Preserves"],"recipeCuisine":["Italian"],"suitableForDiet":["https:\/\/schema.org\/GlutenFreeDiet","https:\/\/schema.org\/VeganDiet","https:\/\/schema.org\/VegetarianDiet"],"keywords":"oven-dried tomatoes, semi-dried tomatoes","nutrition":{"@type":"NutritionInformation","calories":"21 kcal","carbohydrateContent":"2 g","proteinContent":"1 g","fatContent":"1 g","saturatedFatContent":"1 g","sodiumContent":"63 mg","fiberContent":"1 g","sugarContent":"1 g","servingSize":"1 serving"},"@id":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#recipe","isPartOf":{"@id":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/#article"},"mainEntityOfPage":"https:\/\/www.heynutritionlady.com\/semi-dried-tomatoes\/"}]}</script>
	<!-- / Yoast SEO Premium plugin. -->


