</style>
<link data-minify="1" rel='stylesheet' id='simple-social-icons-font-css' href='https://www.heynutritionlady.com/wp-content/cache/min/1/wp-content/plugins/simple-social-icons/css/style.css?ver=1776388904' media='all' />
<link data-minify="1" rel='stylesheet' id='convertkit-admin-quicktags-css' href='https://www.heynutritionlady.com/wp-content/cache/min/1/wp-content/plugins/convertkit/resources/backend/css/quicktags.css?ver=1776388904' media='all' />
<script src="https://www.heynutritionlady.com/wp-includes/js/jquery/jquery.min.js?ver=3.7.1" id="jquery-core-js" data-rocket-defer defer></script>
