			/* added by JB of NP to have the large home page image be full-size so it's not blurry, but maintain a cropped landscape so it isn't too large */
.home .npcrop img{
object-fit:cover;
width:100%;
height:720px !important;
}


.entry-content p {
	    margin-bottom: 17px;
}
.site-title, .entry-title, .widgettitle {
	font-family: 'Roboto', sans-serif !important; 
	letter-spacing: 0; 
	font-size: 2em;
}

.site-header .widget-area .search-form {
	width: 330px;
	float: right;
	margin-right: 25px;
}

.site-header .widget-area .genesis-nav-menu a  {
 font-family: 'Roboto', sans-serif;
	letter-spacing: 0.8px;
	font-size: 18px;
	font-weight: 400;
}

.genesis-nav-menu a {
	padding: 17px 10px;
}
.site-header .widget-area {
	 margin-right: 25px;
	    max-width: 800px;
}

.feastmobilenavbar a img {
	max-height: 60px;
}

.sidebar-primary {
	margin-right: 20px;
}

.genesis-nav-menu a:hover {
	color: #007a53;
	opacity: 1;
}

.footer-widgets-1 {
	margin-top: 30px;
}

.footer-widgets .wrap, .footer-widgets-1, .footer-widgets-4 {
	background: #fff;
}

.gb-block-layout-column-gap-2 {
    grid-gap: 0 8em;
}


h1, h2, h3, h4, h5, h6 {
	color: #007a53;
	font-family: 'Roboto', sans-serif !important; 
	letter-spacing: 0;
	font-weight: 500;
}

.widgettitle {
	color: #000;
}

body {
/* 	font-family: 'PT Sans', sans-serif; */
		letter-spacing: 0.48px;
		font-family: -apple-system, BlinkMacSystemFont, avenir next, avenir, segoe ui, helvetica neue, helvetica, Ubuntu, roboto, noto, arial, sans-serif;
}

#breadcrumbs, .entry-meta {
	font-size: 13px;
}

#breadcrumbs, .entry-meta {
	font-family: -apple-system, BlinkMacSystemFont, avenir next, avenir, segoe ui, helvetica neue, helvetica, Ubuntu, roboto, noto, arial, sans-serif;

}

a, button, input:focus, input[type="button"], input[type="reset"], input[type="submit"], textarea:focus {
    -webkit-transition: none;
    transition: none;
}

.content a, .genesis-nav-menu .current-menu-item > a, a {
color: #007a53;
}

.button, .button-secondary, a.more-link, button, input[type="button"], input[type="reset"], input[type="submit"], .more-from-category a, .sidebar .button, .sidebar .more-from-category a {
	color: #fff;
}

.wprm-recipe-template-hnl-snippets {
    font-family: inherit;
    font-size: 0.9em;
    text-align: center;
    margin-top: 0px;
    margin-bottom: 10px;
}

.wprm-recipe-link.wprm-recipe-link-inline-button {
    display: inline-block;
    margin: 0 5px 5px 0;
}

.recipe-index-search .widgettitle {
	font-size: 23px;
}

/* NerdPress Font Fixes */
.entry-content h1,
.entry-content h3,
.entry-content h4 {
	text-transform: uppercase;
	font-weight: 500;
}

.entry-content h1 {
	font-size: 2em;
}

/* NerdPress font size for accessibility */
body,
input, select, textarea,
.search-form input, input[type=text], input[type=email], input[type=tel], input[type=password], textarea, .archive-pagination {
	font-size: 18px;
}
.home-middle .featuredpost
.wprm-recipe-template-roundup-summary,
.entry-comments h3, 
#respond h3 {
	font-size: 18px;
		font-family: 'Roboto', sans-serif !important; 
}

.sidebar .featured-content .entry-title a {
		font-family: 'Roboto', sans-serif !important; 
		font-size: 0.75em;
	text-transform: uppercase;
	font-weight: 500;
}
.home-bottom .featuredpost,
.entry-comments, 
#respond,
a.more-link, 
.more-from-category a,
.site-footer {
	font-size:18px;
}

.recipes-bottom .widgettitle {
	font-size: 28px;
}

.recipes-bottom .featuredpost h2{
	font-size: 22px;
	text-transform: uppercase;
}
.archive.category .teaser .entry-title a {
	text-transform: uppercase;
	font-size: 18px;
}
.recipes-bottom .featuredpost .post-info, 
.recies-bottom .featuredpost .post-meta {
	font-size: 14px;
	margin-top: 3px;
}

.archive-title {
	text-transform: uppercase;
	font-size: 28px;
	font-weight: 500;
}

.wprm-automatic-recipe-snippets a.wprm-jump-to-recipe-shortcode, .wprm-automatic-recipe-snippets a.wprm-print-recipe-shortcode {
	font-size: 16px;
}
.wprm-recipe-simple h3.wprm-recipe-header {
	font-size: 26px;
}
.wprm-recipe-simple h4.wprm-recipe-group-name {
	font-size: 22px;
}

/* Home page Styles */
.home .nutrition {
float: right;
    margin-top: -50px;
}
.home .gb-block-post-grid {
margin-bottom: -20px;
}
 
.home .gb-block-post-grid .gb-block-post-grid-image img {
float: left;
}
.home .gb-block-post-grid .gb-block-post-grid-image img:hover {
opacity: 1;
}
.home .gb-block-post-grid .gb-block-post-grid-text {
    text-align: left;
    width: 60%;
    float: right;
    background: rgba(255, 255, 255, 0.9);
    margin-top: -550px;
    padding: 40px 100px;
z-index: 999;
}
.home .mobile-only {display:none;}

.home h2 {
color: #000;
}

.home .feast-grid-full a img {
float: left;
}

.home .fsri-title, .home .home .fsci-title {
font-size: 1.05em;
line-height: 1.3;
font-family: 'Roboto', sans-serif !important; 
letter-spacing: 0.8px;
text-transform: uppercase;
color: #000;
}

.home .trending a img {
float: left;
margin-right: 10px;
}

.home .trending .fsri-title {
text-align: left;
}

.home a img {
margin-bottom: 7px;
}
@media only screen and (max-width: 940px) {
.home .wp-block-image {
width: 100%;}
.home .gb-block-post-grid .gb-block-post-grid-text {
margin-top: -483px;
    padding: 40px 70px;
}
}
@media only screen and (max-width: 767px) {

.home .mobile-only {
display:block;
}
.home .npcrop{
display:none;
}
	
.home .gb-block-post-grid .gb-block-post-grid-image img {
float: none;
}
.home .gb-block-post-grid .gb-block-post-grid-image img:hover {
opacity: 1;
}
.home .gb-block-post-grid .gb-block-post-grid-text {
    text-align: left;
    width: 100%;
    float: none;
    background: rgba(255, 255, 255, 0.9);
    margin-top: 0;
    padding: 10px;
z-index: 9;
}

.home .trending {
padding-left: 10px !important;
padding-right:10px!important;
}
}

#mc_embed_signup {
    background: var(--wpr-bg-22d75dc2-e3bb-4646-9e48-6c6f21d44dc9)no-repeat;
    clear: none;
    font: 14px 'Didact Gothic', sans-serif;
}

#mc_embed_signup .button {
    clear: both;
    background-color: #f9423a;
    border: 0 none;
    border-radius: 4px;
    transition: all 0.23s ease-in-out 0s;
    color: #FFFFFF;
    cursor: pointer;
    display: inline-block;
    font-size: 15px;
    font-weight: normal;
    height: 32px;
    line-height: 32px;
    margin: 0 5px 10px 0;
    padding: 0 22px;
    text-align: center;
    text-decoration: none;
    vertical-align: top;
    white-space: nowrap;
    width: auto;
}

.wprm-automatic-recipe-snippets {
	display: none;
}

.wprm-recipe-container > p {
	border: none;
}

.footer-widgets-2 {
	display: none;
}

.footer-widgets-1 {
	width: 100%;
}

.footer-widgets {
	border-top: 3px solid #000;
}

#media_image-4 img, #media_image-5 img {
	width: 100%;
}

	#media_image-4 {
		display: block;
	}
	
	#media_image-5 {
		display: none;
	}

@media(max-width: 800px) {
	#media_image-4 {
		display: none;
	}
	
	#media_image-5 {
		display: block;
	}
}

/* FD LB 2023-11-27 - Feast modern sidebar */
.sidebar h3 {
	color: #000;
	font-family: 'Roboto', sans-serif !important;
	letter-spacing: 0;
	font-size: 2em;
}
.sidebar .fsri-list .fsri-title {
	color: #010101;
	font-family: 'Roboto', sans-serif !important;
	font-size: 20px;
	text-transform: uppercase;
	font-weight: 500;
}

/* FD LB 2024-01-30 - Comment form */
.comment-form-comment-subscribe input {
	display: inline-block;
	width: auto;
	margin-right: 5px;
}
.comment-form-comment-subscribe label {
	display: inline-block;
}

/* FD LB 2024-03-19 - Category archives */
.archive .fsri-title {
	font-weight: 400;
	text-transform: uppercase;
	line-height: 1.6;
}

/* FD KG 2024-04-10 - WPRM user ratings modal */

.wprm-popup-modal-user-rating button {
	border-radius: 0;
	text-transform: uppercase;
	font-size: 13px;
}

/* FD LB 2024-09-19 - Table of Contents block */

.entry-content .toc {
padding: 35px 20px;
}
.entry-content .toc .wp-block-columns {
margin-bottom: 0;
}
.entry-content .toc h2 {
margin-top: 0;
}
.entry-content .toc ul {
margin-top: 0;
margin-bottom: 0;
}
.entry-content .toc ul li {
margin-left: 18px!important;
}
.entry-content .toc .wp-block-columns.is-layout-flex {
gap: 0;
}

@media only screen and (min-width: 782px) {
	.entry-content .toc ul li {
		margin-left: 35px!important;
	}
}

.comment-notes {
	font-size: 12px;
	font-style:italic;
}

/* FD CU 2025-03-21 - main nav styles */
.site-header .widget-area, .site-header .widget-area .genesis-nav-menu {
	max-width: 800px;
}
@media only screen and (min-width: 1200px) {
    .feastmobilenavbar {
        grid-template-columns: 1fr 4fr 0fr 50px !important;
    }
	.modern-menu-desktop-social {
		display: none !important;
	}
	
	/* FD CU  Feast Foodie pro logo height fix */
	.feastmobilenavbar a img {
    margin-top: 8px;
	}
	
}

.feastmobilenavbar {
		height: 90px;
	}
.feastmobilenavbar a img {
	max-height: 90px;
}

/* FD LB 2026-03-11 - Feast subcategory links */
.feast-subcategories-listing .wp-block-buttons {
	margin-top: 15px;
	justify-content: center;
}
.feast-subcategories-listing .wp-block-buttons a {
	color: #fff;
}
		</style>
